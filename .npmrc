# @niclaslindstedt packages (the oss-framework) are published to GitHub
# Packages, which requires authentication even for public reads. Export a
# GITHUB_PAT with the `read:packages` scope before running any npm command:
#
#   export GITHUB_PAT=ghp_...
#
# CI provides the same variable from secrets (see .github/workflows/*).
@niclaslindstedt:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_PAT}
