{
  "name": "game",
  "version": "0.1.0",
  "private": true,
  "description": "Offline top-down survival scroller shooter for the browser: steer by holding pointer/touch; the character auto-acts based on picked-up weapons and items. TypeScript PWA deployed to GitHub Pages.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Niclas Lindstedt <niclas@agilator.se>",
  "type": "module",
  "workspaces": [
    "pwa"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build --workspace pwa",
    "pretest": "npm run assets",
    "test": "vitest run",
    "pretest:watch": "npm run assets",
    "test:watch": "vitest",
    "pretypecheck": "npm run levels",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace pwa",
    "prelint": "npm run assets",
    "lint": "eslint . && npm run typecheck",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "icons": "npm run icons --workspace pwa",
    "assets": "npm run assets --workspace pwa",
    "levels": "npm run levels --workspace pwa",
    "dev": "npm run dev --workspace pwa",
    "native": "npm --prefix native start",
    "native:install": "npm --prefix native install",
    "native:bundle": "npm --prefix native run bundle",
    "native:ios": "npm --prefix native run ios",
    "native:ios:device": "npm --prefix native run ios:device",
    "ios:debug": "npm --prefix native run ios:device:debug",
    "native:android": "npm --prefix native run android"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
