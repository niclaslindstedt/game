{
  "cli": {
    "version": ">= 21.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "android": { "buildType": "apk" }
    },
    "testflight": {
      "autoIncrement": true
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_STORE_PAYMENTS": "required"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
